class Solution {
    public int areaOfMaxDiagonal(int[][] dimensions) {
        int n=dimensions.length;
        int ans=0,md=0;

        for(int i=0;i<n;i++)
        {
            int l=dimensions[i][0];
            int b=dimensions[i][1];
            int sq=l*l+b*b;
            if(sq> md || (sq==md && l * b > ans))
{
    md=sq;
    ans=l*b;
}
        }
        return ans;
    }
}
