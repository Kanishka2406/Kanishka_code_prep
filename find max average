class Solution {
    public double findMaxAverage(int[] nums, int k) {
        int n = nums.length;
        int start = 0;
        int end=0;
        int sum=0;
        int max_sum=Integer.MIN_VALUE;
        for(int numbers : nums)
        {
sum+=numbers;
end++;
while(end - start >k)
{
    sum-=nums[start];
    start++;
}
if(end-start==k)
{
    max_sum=Math.max(max_sum,sum);
}
        }
        return (double) max_sum/k;
    }
}
