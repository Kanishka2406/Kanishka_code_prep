class Solution {
    private int robcheck(int[]nums,int start, int end, int[] memo)
    {
        if(start>end)
        {
            return 0;
        }
        if(memo[start]!=-1)
        {
           return memo[start];
        }
        int st= nums[start]+robcheck(nums,start+2,end,memo);
        int en=robcheck(nums,start+1,end,memo);
        memo[start]= Math.max(st,en);
        return memo[start];
    }
    public int rob(int[] nums) {
        int n = nums.length;

        int memo[] = new int [n];
        Arrays.fill(memo,-1);
        int ans = robcheck(nums,0,n-1,memo);
        return ans;
    }
}
