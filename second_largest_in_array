class Solution {
    public int getSecondLargest(int[] arr) {
        // code here
        int n=arr.length;
       
        int i=0;
        int large=1,sl=-1;
        for(i=0;i<n;i++)
        {
            if(arr[i]>large)
            {
                large=arr[i];
            }
        }
        for(i=0;i<n;i++)
        {
            if((arr[i]>sl) &&(arr[i]!=large))
            {
                sl=arr[i];
            }
        }
        return sl;
    }
}
